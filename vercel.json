{
  "redirects": [
    { "source": "/download", "destination": "/#download", "permanent": false },
    { "source": "/features", "destination": "/#features", "permanent": false },
    { "source": "/menu",     "destination": "/#menu",     "permanent": false },
    { "source": "/(.*)",     "destination": "/",           "permanent": false }
  ],
  "rewrites": [
    { "source": "/contact",         "destination": "/contact.html" },
    { "source": "/privacy",         "destination": "/privacy.html" },
    { "source": "/terms",           "destination": "/terms.html" },
    { "source": "/refund-policy",   "destination": "/refund-policy.html" },
    { "source": "/shipping-policy", "destination": "/shipping-policy.html" }
  ]
}

